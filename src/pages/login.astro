---
import MainLayout from '../layouts/mainLayouts.astro';
import Form from '../components/form/form.astro';
---

<MainLayout
  title="Iniciar Sesión | LinkApps"
  description="Accede a tu cuenta en LinkApps y gestiona tus enlaces personalizados de manera eficiente."
>
<Form
  titulo="Iniciar Sesión"
  input1="Email"
  input2="Password"
  textoBoton="Iniciar Sesión"
  textoBoton2="Registrarse"
  href2="/register"
  textoBoton3="Olvidé mi contraseña"
  mode="login"
/>



</MainLayout>