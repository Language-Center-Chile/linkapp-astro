---
import DashboardLayouts from "../layouts/dashboardLayouts.astro";
import { createClient } from "@/lib/supabase";
import faviconImg from "../assets/favicon.png";

const supabase = createClient({
  request: Astro.request,
  cookies: Astro.cookies,
});

const { data: { user } } = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect("/login");
}

const { data: profile } = await supabase
  .from('profiles')
  .select('nickname, avatar_url, plan')
  .eq('id', user.id)
  .single();

const plan = profile?.plan || "free";
const isPro = plan === "pro";
const nickname = profile?.nickname || "Usuario";
const userAvatar = isPro ? (profile?.avatar_url || "") : "";
const userInitials = nickname[0].toUpperCase();
---

<DashboardLayouts
  title="Dashboard - LinkApp"
  description="Gestiona tus colecciones de enlaces con estilo."
>
  <main id="dashboardMain" data-plan={plan} data-is-pro={isPro.toString()} data-nickname={nickname}>
    <header class="w-full border-b border-white/5 bg-[#0a0a0a] sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src={faviconImg.src} alt="Logo LinkApp" class="w-10 h-10 object-contain" />
          <span class="font-bold text-xl tracking-tighter text-white">LinkApp</span>
          {isPro && <span class="bg-white/10 text-white text-[8px] font-black px-2 py-1 rounded-full uppercase tracking-widest border border-white/20">Pro</span>}
        </div>

        <div class="flex items-center gap-6 relative">
          <div class="hidden md:flex flex-col items-end">
            <span class="text-[10px] font-black uppercase tracking-widest text-muted">Bienvenido</span>
            <span id="headerNickname" class="text-sm font-bold text-white">{nickname}</span>
          </div>
          
          <button id="profileBtn" class="w-10 h-10 rounded-full border border-white/10 overflow-hidden hover:scale-105 transition-transform bg-[#18181b] cursor-pointer">
            {userAvatar ? (
              <img src={userAvatar} alt="Perfil" class="w-full h-full object-cover" />
            ) : (
              <div class="w-full h-full bg-blue/10 flex items-center justify-center text-blue font-black text-xs">
                {userInitials}
              </div>
            )}
          </button>

          <div id="profileMenu" class="absolute right-0 top-14 w-48 bg-[#18181b] border border-white/10 rounded-2xl shadow-2xl py-2 hidden animate-in fade-in slide-in-from-top-2 duration-200 z-[60]">
            <a href="/" id="goHome" class="w-full px-4 py-3 text-left text-xs font-bold text-white hover:bg-white/5 transition-colors flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              Ir al Inicio
            </a>

            {isPro ? (
              <a href="/settings" class="w-full px-4 py-3 text-left text-xs font-bold text-white hover:bg-white/5 transition-colors flex items-center gap-3 border-t border-white/5">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>
                Configuración
              </a>
            ) : (
              <div class="w-full px-4 py-3 text-left text-xs font-bold text-white/20 flex items-center gap-3 border-t border-white/5 cursor-not-allowed">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Ajustes (Solo PRO)
              </div>
            )}
            
            <div class="h-[1px] bg-white/5 my-1"></div>
            
            <button id="logoutBtn" class="w-full px-4 py-3 text-left text-xs font-bold text-red-400 hover:bg-red-400/10 transition-colors flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
              Cerrar Sesión
            </button>
          </div>
        </div>
      </div>
    </header>

    <section class="dashboard-content min-h-[80vh] py-12 px-6">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center mb-12 gap-8">
          <div class="text-center md:text-left">
            <h1 class="text-5xl font-bold tracking-tighter text-white mb-4">
              Mis <span class="gradient-text">Colecciones</span>
            </h1>
            <p class="text-white text-lg font-medium max-w-xl">
              Plan actual: <span class={isPro ? "text-blue uppercase" : "text-muted uppercase"}>{plan}</span>
            </p>

            <div class="flex justify-center md:justify-start gap-4 mt-6">
              <button id="btnBackup" type="button" class="text-[10px] font-black uppercase tracking-widest text-muted hover:text-blue transition-colors flex items-center gap-2">Backup</button>
              <button id="btnRestore" type="button" class="text-[10px] font-black uppercase tracking-widest text-muted hover:text-teal transition-colors flex items-center gap-2">Restaurar</button>
              <input type="file" id="importInput" class="hidden" accept=".json" />
            </div>
          </div>

          <button id="btnNuevaCarpeta" type="button" class="px-10 py-5 bg-[#25a0e7] border border-white/10 hover:bg-blue hover:text-black text-white font-black rounded-3xl transition-all shadow-xl active:scale-95 uppercase tracking-widest text-xs cursor-pointer">+ Nueva Carpeta</button>
        </div>

        <div class="relative mb-12 max-w-2xl mx-auto">
          <div class="absolute left-6 top-1/2 -translate-y-1/2 text-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" x2="16.65" y1="21" x2="16.65"></line></svg>
          </div>
          <input type="text" id="globalSearch" placeholder="Que link estas buscando hoy?" class="w-full bg-[#181717] border-2 border-white/5 text-white p-6 pl-16 rounded-[2.5rem] focus:border-blue outline-none transition-all shadow-2xl" />
        </div>

        <div id="folderGrid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"></div>
      </div>

      <!-- OVERLAY DE COMPARTIR ACTUALIZADO -->
      <div id="shareOverlay" class="share-overlay hidden">
        <div class="share-box relative animate-in fade-in zoom-in duration-200 bg-[#18181b] p-10 rounded-[3rem] border border-white/10 max-w-sm w-full mx-4 overflow-y-auto max-h-[90vh]">
          <button id="closeShare" class="absolute top-6 right-8 text-muted hover:text-white transition-colors text-2xl font-black cursor-pointer">✕</button>
          
          <h3 class="text-2xl font-black text-white uppercase tracking-tighter mb-8 text-center">Compartir Colección</h3>
          
          <div id="qrContainer" class="bg-white p-4 rounded-[2.5rem] w-48 h-48 mx-auto flex items-center justify-center shadow-2xl shadow-blue/20 mb-8">
            <canvas id="qrCanvas" class="w-full h-full"></canvas>
          </div>

          <!-- BOTONES DE REDES SOCIALES -->
          <div class="flex justify-center gap-4 mb-8">
            <a id="shareWA" target="_blank" class="w-10 h-10 bg-green-500/10 text-green-500 rounded-full flex items-center justify-center hover:bg-green-500 hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
            </a>
            <a id="shareX" target="_blank" class="w-10 h-10 bg-white/5 text-white rounded-full flex items-center justify-center hover:bg-white hover:text-black transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
            </a>
            <a id="shareFB" target="_blank" class="w-10 h-10 bg-blue-600/10 text-blue-600 rounded-full flex items-center justify-center hover:bg-blue-600 hover:text-white transition-all">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
          </div>

          <div class="space-y-3 mb-8">
            <p class="text-[10px] font-black uppercase tracking-widest text-muted text-center">Enlace de acceso</p>
            <div class="flex gap-2">
              <input type="text" id="shareUrl" readonly class="w-full bg-black/40 border border-white/10 text-white p-4 rounded-xl text-xs outline-none focus:border-blue/50" />
              <button id="copyUrl" class="bg-blue text-white px-6 rounded-xl font-black text-[10px] uppercase hover:bg-blue/80 transition-all cursor-pointer">Copiar</button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</DashboardLayouts>

<script>
  // @ts-nocheck
  import Swal from "sweetalert2";
  import QRCode from "qrcode";
  import { supabaseBrowser } from "../lib/supabase"; 

  const main = document.getElementById('dashboardMain');
  const isPro = main?.dataset.isPro === 'true';
  const nicknameGlobal = main?.dataset.nickname || "Usuario";
  const LIMIT_FOLDERS = isPro ? 1000 : 2;
  const LIMIT_LINKS = isPro ? 10000 : 2;

  let carpetas = [];
  let userId = null;

  const swalConfig = {
    confirmButtonColor: "#38BDF8",
    cancelButtonColor: "#6b7280",
    background: "#18181b",
    color: "#fff",
  };

  const profileBtn = document.getElementById('profileBtn');
  const profileMenu = document.getElementById('profileMenu');
  
  profileBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    profileMenu?.classList.toggle('hidden');
  });

  document.addEventListener('click', () => {
    profileMenu?.classList.add('hidden');
  });

  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    await supabaseBrowser.auth.signOut();
    window.location.href = "/login";
  });

  const shareOverlay = document.getElementById('shareOverlay');
  const closeShare = document.getElementById('closeShare');
  const copyUrlBtn = document.getElementById('copyUrl');
  const shareUrlInput = document.getElementById('shareUrl');
  const qrCanvas = document.getElementById('qrCanvas');

  const shareWA = document.getElementById('shareWA');
  const shareX = document.getElementById('shareX');
  const shareFB = document.getElementById('shareFB');

  closeShare?.addEventListener('click', () => shareOverlay?.classList.add('hidden'));
  
  copyUrlBtn?.addEventListener('click', () => {
    shareUrlInput.select();
    document.execCommand('copy');
    Swal.fire({ title: "Copiado", text: "Enlace copiado al portapapeles", icon: "success", timer: 1500, showConfirmButton: false, ...swalConfig });
  });

  function escapeHtml(str) {
    if (!str) return "";
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  async function cargarDatos() {
    const { data: { user } } = await supabaseBrowser.auth.getUser();
    if (!user) return;
    userId = user.id;

    const { data, error } = await supabaseBrowser
      .from('linkapp_folders')
      .select('content')
      .eq('user_id', userId);

    if (!error) {
      carpetas = data && data.length > 0 ? data[0].content : [];
      renderCarpetas();
    }
  }

  async function actualizarDB(nuevasCarpetas) {
    if (!userId) return false;
    const { error } = await supabaseBrowser
      .from('linkapp_folders')
      .upsert({ 
        user_id: userId, 
        content: nuevasCarpetas,
        updated_at: new Date().toISOString() 
      }, { onConflict: 'user_id' });

    if (error) {
      Swal.fire({ ...swalConfig, title: "Error", text: error.message, icon: "error" });
      return false;
    }
    carpetas = nuevasCarpetas;
    return true;
  }

  function renderCarpetas(lista = carpetas) {
    const grid = document.getElementById("folderGrid");
    if (!grid) return;
    grid.innerHTML = "";

    if (!lista || lista.length === 0) {
      grid.innerHTML = `<div class="col-span-full text-center py-20 opacity-50 text-white font-black uppercase text-xs tracking-widest">No hay colecciones creadas</div>`;
      return;
    }

    grid.innerHTML = lista.map((folder, index) => {
      const isBlocked = !isPro && index >= LIMIT_FOLDERS;
      const links = Array.isArray(folder.links) ? folder.links : [];
      
      return `
        <div class="folder-card border border-white/5 rounded-[2.5rem] p-8 flex flex-col h-full bg-[#18181b] animate-fade-in shadow-xl relative overflow-hidden">
          
          ${isBlocked ? `
            <div class="absolute inset-0 z-20 flex flex-col items-center justify-center bg-black/60 backdrop-blur-md">
                <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#38BDF8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mb-2"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                <span class="text-[10px] font-black text-white uppercase tracking-widest">Bloqueado (Solo PRO)</span>
            </div>
          ` : ''}

          <div class="flex justify-between items-start mb-6 gap-4">
            <h3 class="text-xl font-black text-white truncate">${escapeHtml(folder.nombre)}</h3>
            <div class="flex gap-2">
              <button data-action="compartir-carpeta" data-index="${index}" class="text-muted hover:text-blue transition-transform hover:scale-125 cursor-pointer">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" x2="12" y1="2" y2="15"/></svg>
              </button>
              <button data-action="eliminar-carpeta" data-index="${index}" class="text-muted hover:text-red-400 transition-transform hover:scale-125 cursor-pointer">✕</button>
            </div>
          </div>
          <div class="space-y-2 mb-6 flex-1">
            ${links.length === 0 
              ? '<p class="text-[10px] text-muted uppercase tracking-widest text-center py-4">Sin links aún</p>'
              : links.map((link, li) => `
                <div class="flex items-center justify-between bg-white/[0.03] p-3 rounded-xl border border-transparent hover:border-blue/20 transition-all group gap-2">
                  <a href="${link.url}" target="_blank" class="text-xs font-bold text-white hover:text-blue truncate flex-1">${escapeHtml(link.tag || link.url)}</a>
                  <button data-action="eliminar-link" data-folder="${index}" data-link="${li}" class="text-muted hover:text-red-400 opacity-0 group-hover:opacity-100 transition-opacity text-xs px-2 cursor-pointer">✕</button>
                </div>
              `).join('')
            }
          </div>
          <button data-action="agregar-link" data-index="${index}" class="w-full py-3 bg-blue/10 text-blue rounded-xl font-black text-[9px] uppercase tracking-tighter hover:bg-blue hover:text-black transition-all cursor-pointer">+ Añadir Enlace</button>
        </div>
      `;
    }).join('');
  }

  document.getElementById("btnNuevaCarpeta")?.addEventListener("click", async () => {
    if (carpetas.length >= LIMIT_FOLDERS) {
      return Swal.fire({ title: "Límite alcanzado", text: isPro ? "Límite de 1000 alcanzado." : "El plan FREE solo permite 2 carpetas.", icon: "warning", ...swalConfig });
    }
    const { value: nombre } = await Swal.fire({ title: "Nueva Carpeta", input: "text", ...swalConfig, showCancelButton: true });
    if (nombre) {
      const nueva = [...carpetas, { id: crypto.randomUUID(), nombre: nombre.trim(), links: [], created_at: new Date().toISOString() }];
      if (await actualizarDB(nueva)) renderCarpetas();
    }
  });

  document.addEventListener("click", async (e) => {
    const btn = e.target.closest("[data-action]");
    if (!btn) return;
    const action = btn.dataset.action;
    const index = Number(btn.dataset.index);

    if (action === "compartir-carpeta") {
      const folder = carpetas[index];

      // NUEVA LÓGICA CON SUPABASE TABLE
      const { data: sharedData, error: sharedError } = await supabaseBrowser
        .from('shared_collections')
        .insert({
          owner_id: userId,
          owner_nickname: nicknameGlobal,
          content: {
            n: folder.nombre,
            l: folder.links
          }
        })
        .select('id')
        .single();

      if (sharedError) {
        return Swal.fire({ title: "Error", text: "No se pudo generar el link seguro.", icon: "error", ...swalConfig });
      }

      const shareUrl = `${window.location.origin}/view?id=${sharedData.id}`;
      
      if (shareUrlInput) shareUrlInput.value = shareUrl;

      if (qrCanvas) {
        QRCode.toCanvas(qrCanvas, shareUrl, {
          width: 180,
          margin: 0,
          color: { dark: '#000000', light: '#ffffff' }
        }, (err) => {
          if (err) console.error(err);
        });
      }

      const text = `¡Mira mi colección "${folder.nombre}" en LinkApp!`;
      shareWA.href = `https://wa.me/?text=${encodeURIComponent(text + " " + shareUrl)}`;
      shareX.href = `https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(shareUrl)}`;
      shareFB.href = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`;

      shareOverlay?.classList.remove('hidden');
      return;
    }

    if (action === "agregar-link") {
      if (!isPro && carpetas[index].links.length >= LIMIT_LINKS) {
        return Swal.fire({ title: "Límite de Enlaces", text: "El plan FREE solo permite 2 enlaces por carpeta.", icon: "warning", ...swalConfig });
      }
      const { value: fv } = await Swal.fire({
        title: "Añadir Enlace",
        html: `<input id="swal-url" class="swal2-input" placeholder="https://..."><input id="swal-tag" class="swal2-input" placeholder="Nombre">`,
        ...swalConfig,
        showCancelButton: true,
        preConfirm: () => ({ url: document.getElementById("swal-url").value, tag: document.getElementById("swal-tag").value })
      });
      if (fv?.url) {
        carpetas[index].links.push(fv);
        if (await actualizarDB(carpetas)) renderCarpetas();
      }
    }

    if (action === "eliminar-carpeta") {
      const res = await Swal.fire({ title: "¿Eliminar?", icon: "warning", showCancelButton: true, ...swalConfig });
      if (res.isConfirmed) {
        carpetas.splice(index, 1);
        if (await actualizarDB(carpetas)) renderCarpetas();
      }
    }

    if (action === "eliminar-link") {
      const folderIdx = Number(btn.dataset.folder);
      const linkIdx = Number(btn.dataset.link);
      carpetas[folderIdx].links.splice(linkIdx, 1);
      if (await actualizarDB(carpetas)) renderCarpetas();
    }
  });

  cargarDatos();
</script>

<style>
  .gradient-text {
    background: linear-gradient(90deg, #38bdf8, #2dd4bf);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .folder-card { transition: all 0.4s ease; }
  .folder-card:hover { transform: translateY(-4px); }
  .share-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px);
    z-index: 100; display: none; align-items: center; justify-content: center;
  }
  .share-overlay:not(.hidden) { display: flex; }
  #qrCanvas {
    width: 100% !important;
    height: 100% !important;
    border-radius: 1.5rem;
  }
</style>