  async function createFolder() {
    if (carpetas.length >= LIMIT_FOLDERS_FREE) {
      await Swal.fire({
        title: "Límite Alcanzado",
        text: "El plan gratuito permite un máximo de 2 carpetas. ¡Actualiza a PRO para más!",
        icon: "warning",
        confirmButtonColor: "#38BDF8",
        background: "#18181b",
        color: "#fff",
      });
      return;
    }

    const { value: nombre } = await Swal.fire({
      title: "Nueva Carpeta",
      input: "text",
      inputLabel: "Nombre de la colección",
      inputPlaceholder: "Ej: Mis Links Favoritos",
      showCancelButton: true,
      confirmButtonText: "Crear",
      cancelButtonText: "Cancelar",
      confirmButtonColor: "#38BDF8",
      cancelButtonColor: "#6b7280",
      background: "#18181b",
      color: "#fff",
      inputValidator: (value) => {
        if (!value?.trim()) return "El nombre es obligatorio";
        if (value.trim().length > 50) return "Máximo 50 caracteres";
      },
    });

    if (!nombre?.trim()) return;

    const updatedFolders = [
      ...carpetas,
      {
        id: crypto.randomUUID(),
        nombre: nombre.trim(),
        links: [],
        created_at: new Date().toISOString(),
      },
    ];

    const error = await guardarCarpetas(updatedFolders);

    if (error) {
      await swalError(error.message || "No se pudo crear la carpeta");
      return;
    }

    carpetas = updatedFolders;
    renderCarpetas();

    await Swal.fire({
      title: "¡Creada!",
      text: "Tu nueva carpeta está lista",
      icon: "success",
      confirmButtonColor: "#38BDF8",
      background: "#18181b",
      color: "#fff",
      timer: 2000,
      showConfirmButton: false,
    });
  }

  async function agregarLink(index) {
    if (!carpetas[index]) {
      await swalError("La carpeta no existe");
      return;
    }

    const { value: formValues } = await Swal.fire({
      title: "Añadir Enlace",
      html: `
        <input id="swal-url" class="swal2-input" placeholder="https://ejemplo.com" type="url">
        <input id="swal-tag" class="swal2-input" placeholder="Nombre o etiqueta (opcional)">
      `,
      confirmButtonText: "Añadir",
      cancelButtonText: "Cancelar",
      showCancelButton: true,
      confirmButtonColor: "#38BDF8",
      cancelButtonColor: "#6b7280",
      background: "#18181b",
      color: "#fff",
      preConfirm: () => {
        const url = document.getElementById("swal-url")?.value?.trim();
        const tag = document.getElementById("swal-tag")?.value?.trim();

        if (!url) {
          Swal.showValidationMessage("La URL es obligatoria");
          return false;
        }

        try {
          new URL(url);
        } catch {
          Swal.showValidationMessage("URL inválida");
          return false;
        }

        return { url, tag };
      },
    });

    if (!formValues) return;

    const updatedFolders = structuredClone(carpetas);
    if (!Array.isArray(updatedFolders[index].links)) {
      updatedFolders[index].links = [];
    }

    updatedFolders[index].links.push({
      url: formValues.url,
      tag: formValues.tag || "",
    });

    const error = await guardarCarpetas(updatedFolders);

    if (error) {
      await swalError(error.message || "No se pudo guardar el link");
      return;
    }

    carpetas = updatedFolders;
    renderCarpetas();
  }

  async function eliminarLink(folderIndex, linkIndex) {
    if (!carpetas[folderIndex]?.links?.[linkIndex]) {
      await swalError("El link no existe");
      return;
    }

    const result = await Swal.fire({
      title: "¿Eliminar link?",
      icon: "warning",
      showCancelButton: true,
      confirmButtonText: "Sí, eliminar",
      cancelButtonText: "Cancelar",
      confirmButtonColor: "#ef4444",
      cancelButtonColor: "#6b7280",
      background: "#18181b",
      color: "#fff",
    });

    if (!result.isConfirmed) return;

    const updatedFolders = structuredClone(carpetas);
    updatedFolders[folderIndex].links.splice(linkIndex, 1);

    const error = await guardarCarpetas(updatedFolders);

    if (error) {
      await swalError(error.message || "No se pudo eliminar el link");
      return;
    }

    carpetas = updatedFolders;
    renderCarpetas();
  }

  async function eliminarCarpeta(index) {
    if (!carpetas[index]) {
      await swalError("La carpeta no existe");
      return;
    }

    const result = await Swal.fire({
      title: "¿Eliminar carpeta?",
      text: "Se borrarán todos los links dentro de ella.",
      icon: "warning",
      showCancelButton: true,
      confirmButtonText: "Sí, eliminar",
      cancelButtonText: "Cancelar",
      confirmButtonColor: "#ef4444",
      cancelButtonColor: "#6b7280",
      background: "#18181b",
      color: "#fff",
    });

    if (!result.isConfirmed) return;

    const updatedFolders = carpetas.filter((_, i) => i !== index);
    const error = await guardarCarpetas(updatedFolders);

    if (error) {
      await swalError(error.message || "No se pudo eliminar la carpeta");
      return;
    }

    carpetas = updatedFolders;
    renderCarpetas();
  }

  function handleSearch(event) {
    const query = event.target.value.toLowerCase().trim();

    if (!query) {
      renderCarpetas();
      return;
    }

    const filtradas = carpetas
      .map((folder) => ({
        ...folder,
        links: (Array.isArray(folder.links) ? folder.links : []).filter((l) => {
          const url = l.url?.toLowerCase?.() || "";
          const tag = l.tag?.toLowerCase?.() || "";
          return url.includes(query) || tag.includes(query);
        }),
      }))
      .filter((folder) => {
        const nombre = folder.nombre?.toLowerCase?.() || "";
        return nombre.includes(query) || folder.links.length > 0;
      });

    renderCarpetas(filtradas);
  }

  function handleBackup() {
    const blob = new Blob([JSON.stringify(carpetas, null, 2)], {
      type: "application/json",
    });

    const a = document.createElement("a");
    a.href = URL.createObjectURL(blob);
    a.download = `linkapp-backup-${Date.now()}.json`;
    a.click();

    setTimeout(() => URL.revokeObjectURL(a.href), 1000);
  }

  async function handleRestoreChange(event) {
    const file = event.target.files?.[0];
    if (!file) return;

    try {
      const imported = JSON.parse(await file.text());

      if (!Array.isArray(imported)) {
        throw new Error("Formato inválido");
      }

      const sanitized = imported.map((folder) => ({
        id: folder.id || crypto.randomUUID(),
        nombre: String(folder.nombre || "Sin nombre").trim(),
        links: Array.isArray(folder.links)
          ? folder.links
              .filter((link) => link?.url)
              .map((link) => ({
                url: String(link.url).trim(),
                tag: String(link.tag || "").trim(),
              }))
          : [],
        created_at: folder.created_at || new Date().toISOString(),
      }));

      const error = await guardarCarpetas(sanitized);

      if (error) {
        await swalError(error.message || "No se pudo restaurar el backup");
        return;
      }

      carpetas = sanitized;
      renderCarpetas();

      await Swal.fire({
        title: "¡Restaurado!",
        icon: "success",
        confirmButtonColor: "#38BDF8",
        background: "#18181b",
        color: "#fff",
        timer: 2000,
        showConfirmButton: false,
      });
    } catch (error) {
      await swalError(error.message || "Archivo inválido o formato incorrecto");
    } finally {
      event.target.value = "";
    }
  }

