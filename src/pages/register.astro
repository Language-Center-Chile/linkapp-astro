---
import MainLayout from "../layouts/mainLayouts.astro";
import Form from "../components/form/form.astro";
---

<MainLayout
  title="Registrarse | LinkApps"
  description="Crea tu cuenta en LinkApps y empieza a gestionar tus enlaces personalizados."
>
  <Form
    titulo="Registrarse"
    input1="Username"
    input2="Password"
    input3="E-mail"
    input4="Confirm Password"
    textoBoton="Registrarse"
    mode="register"
  />
</MainLayout>