---
import MainLayout from "../layouts/mainLayouts.astro";
---

<MainLayout
  title="Contacto | LinkApp"
  description="¿Tienes dudas o sugerencias? Ponte en contacto con el equipo de LinkApp."
>
  <section class="relative min-h-screen flex flex-col items-center justify-center px-6 py-24 overflow-hidden">
    
    <div class="relative z-10 max-w-4xl w-full">
      <header class="text-center mb-16">
        <h1 class="text-5xl md:text-7xl font-black tracking-tighter uppercase text-white mb-6">
          Ponte en <span class="gradient-text">Contacto</span>
        </h1>
        <p class="text-zinc-200 text-lg md:text-xl max-w-2xl mx-auto leading-relaxed font-medium custom-shadow text-center">
          Estamos aquí para ayudarte a optimizar tu presencia digital. Escríbenos y te responderemos lo antes posible.
        </p>
      </header>

      <div class="grid md:grid-cols-2 gap-8 items-stretch">
        <!-- Información de contacto corregida -->
        <div class="bg-[#18181b] border border-white/10 p-8 md:p-10 rounded-[2.5rem] shadow-2xl flex flex-col justify-between overflow-hidden">
          <div class="space-y-8 w-full">
            <div class="w-full">
              <h3 class="text-[10px] font-black uppercase tracking-[0.3em] text-blue mb-4">Correo Electrónico</h3>
              <!-- Ajuste de tamaño y break-words para evitar descuadre -->
              <a 
                href="mailto:contacto@languagecenterchile.com" 
                class="text-xl sm:text-2xl font-bold text-white hover:text-blue transition-colors break-words block leading-tight"
              >
                contacto@languagecenterchile.com
              </a>
            </div>
            
            <div>
              <h3 class="text-[10px] font-black uppercase tracking-[0.3em] text-green-400 mb-4">Soporte</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">
                Nuestro equipo técnico está disponible para resolver incidencias con tu cuenta o configuración de carpetas.
              </p>
            </div>
          </div>

          <div class="pt-8 mt-8 border-t border-white/5">
            <p class="text-[10px] font-black uppercase tracking-widest text-zinc-500">
              Respuesta estimada: Menos de 24 horas
            </p>
          </div>
        </div>

        <!-- Formulario -->
        <form class="bg-[#18181b] border border-white/10 p-8 md:p-10 rounded-[2.5rem] shadow-2xl space-y-6">
          <div class="space-y-2">
            <label class="text-[10px] text-zinc-500 uppercase font-black tracking-widest ml-2">Nombre</label>
            <input type="text" placeholder="Tu nombre" class="w-full bg-black/40 border border-white/10 p-4 rounded-2xl outline-none focus:border-blue transition-all text-white font-medium">
          </div>

          <div class="space-y-2">
            <label class="text-[10px] text-zinc-500 uppercase font-black tracking-widest ml-2">Asunto</label>
            <input type="text" placeholder="¿En qué podemos ayudarte?" class="w-full bg-black/40 border border-white/10 p-4 rounded-2xl outline-none focus:border-blue transition-all text-white font-medium">
          </div>

          <div class="space-y-2">
            <label class="text-[10px] text-zinc-500 uppercase font-black tracking-widest ml-2">Mensaje</label>
            <textarea rows="4" placeholder="Escribe tu mensaje aquí..." class="w-full bg-black/40 border border-white/10 p-4 rounded-2xl outline-none focus:border-blue transition-all text-white font-medium resize-none"></textarea>
          </div>

          <button type="submit" class="w-full py-4 bg-white text-black font-black rounded-2xl hover:scale-[1.02] active:scale-95 transition-all uppercase tracking-widest text-xs">
            Enviar Mensaje
          </button>
        </form>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .gradient-text {
    background: linear-gradient(135deg, #00f2ff 0%, #4ade80 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .custom-shadow {
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.8));
  }

  .text-blue {
    color: #00f2ff;
  }
</style>