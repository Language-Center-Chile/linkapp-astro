---

import Texto from "./texto.astro"

---

<div class="card">
  <div class="card2">
    <Texto 
      title={Astro.props.title}
      description={Astro.props.description}
      price={Astro.props.price}
      features={Astro.props.features}
      texto={Astro.props.texto}
    />
  </div>
</div>

<style>
    /* From Uiverse.io by Tiagoadag */ 
.card {
 width: 190px;
 background-image: linear-gradient(163deg, #00ff75 0%, #3700ff 100%);
 border-radius: 20px;
 transition: all .3s;
 display: flex;
 flex-direction: column;
}

.card2 {
 width: 190px;
 background-color: #1a1a1a;
 border-radius: 20px;
 transition: all .2s;
 flex: 1;
 display: flex;
 flex-direction: column;
}

.card2:hover {
 transform: scale(0.98);
 border-radius: 20px;
}

.card:hover {
 box-shadow: 0px 0px 30px 1px rgba(0, 255, 117, 0.30);
}
</style>