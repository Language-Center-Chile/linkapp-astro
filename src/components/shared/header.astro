---
const { user } = Astro.props;
---

<header class="border-b border-border sticky top-0 bg-black/80 backdrop-blur-md z-50">
  <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
    
    <!-- Logo y Nombre -->
    <a href="/" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
      <img src="/logo.png" alt="logo" class="w-10 h-12 object-contain">
      <span class="font-bold text-xl tracking-tighter text-white">LinkApp</span>
    </a>

    <!-- Navegacion Desktop -->
    <nav class="hidden md:flex items-center gap-8 text-sm">
      <div class="flex gap-6 border-r border-border pr-6 font-medium">
        <a href="/" class="text-white hover:text-blue transition-colors">Inicio</a>
        <a href="/about" class="text-muted hover:text-blue transition-colors">Nosotros</a>
        <a href="/contact" class="text-muted hover:text-blue transition-colors">Contacto</a>
        <a href="/subscription" class="text-muted hover:text-blue transition-colors">Suscripcion</a>
      </div>

      <!-- Zona de Autenticacion Dinamica -->
      <div class="flex gap-4 items-center">
        {!user ? (
          <>
            <a href="/login" class="px-5 py-2 text-muted hover:text-white transition-colors text-xs font-black uppercase tracking-widest">
              Login
            </a>
            <a href="/register" class="px-5 py-2.5 bg-blue text-black rounded-xl text-xs font-black uppercase tracking-widest hover:scale-105 transition-all shadow-lg shadow-blue/20">
              Registrarse
            </a>
          </>
        ) : (
          <>
            <a href="/dashboard" class="px-5 py-2.5 bg-teal text-black rounded-xl text-xs font-black uppercase tracking-widest hover:scale-105 transition-all shadow-lg shadow-teal/20">
              Mi Panel
            </a>
            <button id="logout-btn" class="text-muted hover:text-red-400 transition-colors text-[10px] font-black uppercase tracking-widest">
              Salir
            </button>
          </>
        )}
      </div>
    </nav>
    
    <!-- Boton Menu Movil -->
    <button id="menu-btn" class="md:hidden text-white text-3xl focus:outline-none hover:text-blue transition-colors">
      <span id="menu-icon">&#9776;</span>
    </button>
  </div>

  <!-- Menu Movil Dinamico -->
  <div id="mobile-menu" class="hidden absolute top-20 left-0 w-full bg-black/95 backdrop-blur-xl border-b border-border p-8 flex flex-col items-center text-center gap-6 md:hidden z-40 shadow-2xl">
    <div class="flex flex-col gap-5 w-full">
      <a href="/" class="text-white text-lg font-bold uppercase tracking-widest">Inicio</a>
      <a href="/about" class="text-muted hover:text-blue text-lg font-bold uppercase tracking-widest">Nosotros</a>
      <a href="/contact" class="text-muted hover:text-blue text-lg font-bold uppercase tracking-widest">Contacto</a>
      <a href="/subscription" class="text-muted hover:text-blue text-lg font-bold uppercase tracking-widest">Suscripcion</a>
    </div>

    <div class="h-px bg-border w-1/2 my-2"></div>

    <div class="flex flex-col gap-4 w-full max-w-xs">
      {!user ? (
        <>
          <a href="/login" class="text-center py-4 border border-border rounded-xl text-muted hover:text-white text-xs font-black uppercase tracking-widest">
            Login
          </a>
          <a href="/register" class="text-center py-4 bg-blue text-black rounded-xl text-xs font-black uppercase tracking-widest shadow-lg shadow-blue/20">
            Registrarse
          </a>
        </>
      ) : (
        <>
          <a href="/dashboard" class="text-center py-4 bg-teal text-black rounded-xl text-xs font-black uppercase tracking-widest shadow-lg shadow-teal/20">
            Ir a mi Panel
          </a>
          <button id="logout-btn-mobile" class="text-red-400 font-bold uppercase text-[10px] tracking-widest py-2">
            Cerrar Sesion
          </button>
        </>
      )}
    </div>
  </div>
</header>

<script>
  import { supabaseBrowser } from "@/lib/supabase";

  const logoutButtons = document.querySelectorAll('#logout-btn, #logout-btn-mobile');

  logoutButtons.forEach(btn => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      
      await supabaseBrowser.auth.signOut();
      
      const cookies = document.cookie.split(";");
      for (let i = 0; i < cookies.length; i++) {
        const cookie = cookies[i];
        const eqPos = cookie.indexOf("=");
        const name = eqPos > -1 ? cookie.substring(0, eqPos) : cookie;
        document.cookie = name + "=;expires=Thu, 01 Jan 1970 00:00:00 GMT;path=/";
      }

      window.location.href = "/"; 
    });
  });

  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  menuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
    if (menuIcon) {
      menuIcon.textContent = mobileMenu?.classList.contains('hidden') ? '&#9776;' : 'x';
    }
  });
</script>

<style>
  .text-muted { color: #888; }
  .bg-blue { background-color: #3b82f6; }
  .bg-teal { background-color: #14b8a6; }
  .border-border { border-color: rgba(255, 255, 255, 0.1); }

  #mobile-menu:not(.hidden) {
    animation: slideDown 0.3s ease-out forwards;
  }

  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
