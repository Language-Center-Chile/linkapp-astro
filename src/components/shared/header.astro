---
import Button from "../ui/buttons/button-nav.astro";
import Sdas from "../ui/buttons/button.astro";

---

<nav>

<a id="logo" href="/"><img src="/favicon.png" alt="LinkApps logo" height="32" /></a>
  <div id="nav-links">
  <a href="/about" style="text-decoration: none;">
    <Button text="Nosotros" />
  </a>
  <a href="/contact" style="text-decoration: none;">
    <Button text="Contacto" />
  </a>
  <a href="/subscription" style="text-decoration: none;">
    <Button text="Suscripción" />
  </a>
</div>
  <a href="/register" id="btn-iniciar-session">
    <Sdas />
  </a>
  
</nav>
<style>
nav {
    background-color: black;
    display: flex;
    align-items: center;
    padding: 0.5rem 1rem;
}
#logo img {
  height: 60px;
  width: auto;
  display: block;
  padding-left: 25px;
}
#nav-links {
  display: flex;
  gap: 1.5rem;
  margin-left: auto;
}
#btn-iniciar-session{

  padding-left: 25px;

}

</style>