<script>
  const form = document.getElementById("auth-form") as HTMLFormElement | null;
  const message = document.getElementById("form-message") as HTMLElement | null;
  const mode = form?.dataset.mode ?? "register";
  const passwordModal = document.getElementById("password-modal");
  const passwordModalClose = document.getElementById("password-modal-close");
  const incorrectPasswordModal = document.getElementById("incorrect-password-modal");
  const incorrectPasswordModalClose = document.getElementById("incorrect-password-modal-close");
  const shortPasswordModal = document.getElementById("short-password-modal");
  const shortPasswordModalClose = document.getElementById("short-password-modal-close");
  const rateLimitModal = document.getElementById("rate-limit-modal");
  const rateLimitModalClose = document.getElementById("rate-limit-modal-close");

  passwordModalClose?.addEventListener("click", () => {
    passwordModal?.classList.remove("modal-visible");
    passwordModal?.setAttribute("aria-hidden", "true");
  });

  incorrectPasswordModalClose?.addEventListener("click", () => {
    incorrectPasswordModal?.classList.remove("modal-visible");
    incorrectPasswordModal?.setAttribute("aria-hidden", "true");
  });

  shortPasswordModalClose?.addEventListener("click", () => {
    shortPasswordModal?.classList.remove("modal-visible");
    shortPasswordModal?.setAttribute("aria-hidden", "true");
  });

  rateLimitModalClose?.addEventListener("click", () => {
    rateLimitModal?.classList.remove("modal-visible");
    rateLimitModal?.setAttribute("aria-hidden", "true");
  });


  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (!form || !message) return;

    const formData = new FormData(form);

    if (mode === "login") {
      const email = formData.get("email") as string;
      const password = formData.get("password") as string;

      if (!email || !password) {
        incorrectPasswordModal?.classList.add("modal-visible");
        incorrectPasswordModal?.setAttribute("aria-hidden", "false");
        return;
      }

      const response = await fetch("/api/auth/login", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email, password }),
      });

      const result = await response.json();

      if (!response.ok) {
        incorrectPasswordModal?.classList.add("modal-visible");
        incorrectPasswordModal?.setAttribute("aria-hidden", "false");
        return;
      }

      message.textContent = "¡Bienvenido!";
      setTimeout(() => { window.location.href = "/dashboard"; }, 800);

    } else {
      const username = formData.get("username") as string;
      const email = formData.get("email") as string;
      const password = formData.get("password") as string;
      const confirmPassword = formData.get("confirmPassword") as string;

      if (!username || !email || !password || !confirmPassword) {
        message.textContent = "Completa todos los campos";
        return;
      }

      if (password !== confirmPassword) {
        passwordModal?.classList.add("modal-visible");
        passwordModal?.setAttribute("aria-hidden", "false");
        return;
      }

      if (password.length < 6) {
        shortPasswordModal?.classList.add("modal-visible");
        shortPasswordModal?.setAttribute("aria-hidden", "false");
        return;
      }

      const response = await fetch("/api/auth/register", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ username, email, password }),
      });

      const result = await response.json();

      if (!response.ok) {
        if (result.message?.toLowerCase().includes("rate limit") || result.message?.toLowerCase().includes("email rate")) {
          rateLimitModal?.classList.add("modal-visible");
          rateLimitModal?.setAttribute("aria-hidden", "false");
        } else {
          message.textContent = result.message || "Error al registrarse";
        }
        return;
      }

      message.textContent = "Cuenta creada correctamente";
      form.reset();
      setTimeout(() => { window.location.href = "/login"; }, 800);
    }
  });
</script>

